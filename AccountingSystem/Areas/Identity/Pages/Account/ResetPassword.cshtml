@page
@model AccountingSystem.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<h1>@ViewData["Title"]</h1>
<p class="text-muted">Choose a new password.</p>
<hr />

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post" class="row g-3">
    <div asp-validation-summary="All" class="text-danger"></div>

    <input type="hidden" asp-for="Input.Code" />
    <input type="hidden" asp-for="Input.UserId" />

    <div class="col-md-6">
        <label class="form-label">Email</label>
        <input class="form-control" asp-for="Input.Email" readonly />
    </div>

    <div class="col-md-6">
        <label class="form-label">User ID</label>
        <input class="form-control" value="@Model.Input.UserId" readonly />
    </div>

    <div class="col-md-6">
        <label class="form-label">New Password</label>
        <input class="form-control" asp-for="Input.Password" type="password" autocomplete="new-password" />
        <span class="text-danger" asp-validation-for="Input.Password"></span>
    </div>

    <div class="col-md-6">
        <label class="form-label">Confirm New Password</label>
        <input class="form-control" asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
        <span class="text-danger" asp-validation-for="Input.ConfirmPassword"></span>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Reset Password</button>
        <a class="btn btn-outline-secondary ms-1" asp-page="./Login">Back to Login</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}