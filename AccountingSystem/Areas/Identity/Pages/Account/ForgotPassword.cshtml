@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<h1>@ViewData["Title"]</h1>
<h2>Enter your email.</h2>
<hr />

@if (!string.IsNullOrEmpty(Model.ResetLink))
{
    <div class="alert alert-warning mt-3">
        <strong>Development mode:</strong><br />
        Copy this reset link and open it in a new tab:
        <div class="mt-2">
            <input class="form-control" value="@Model.ResetLink" readonly />
        </div>
        <div class="mt-2">
            <a class="btn btn-sm btn-outline-primary" href="@Model.ResetLink" target="_blank" rel="noopener noreferrer">
                Open Reset Link
            </a>
        </div>
    </div>
}

<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="form-label"></label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <button type="submit" class="w-100 btn btn-lg btn-primary">Generate Reset Link</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
