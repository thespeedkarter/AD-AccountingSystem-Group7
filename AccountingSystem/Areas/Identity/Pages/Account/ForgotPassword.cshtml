@page
@model AccountingSystem.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<h1>@ViewData["Title"]</h1>
<p class="text-muted">
    Enter your Email + User ID, answer your security question, and we will generate a reset link.
</p>

<hr />

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post" class="row g-3">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="col-md-6">
        <label class="form-label">Email</label>
        <input class="form-control" asp-for="Input.Email" autocomplete="email" />
        <span class="text-danger" asp-validation-for="Input.Email"></span>
    </div>

    <div class="col-md-6">
        <label class="form-label">User ID</label>
        <input class="form-control" asp-for="Input.UserId" autocomplete="off" />
        <span class="text-danger" asp-validation-for="Input.UserId"></span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SecurityQuestion))
    {
        <div class="col-12">
            <div class="alert alert-secondary mb-0">
                <strong>Security Question:</strong> @Model.SecurityQuestion
            </div>
        </div>

        <div class="col-12">
            <label class="form-label">Security Answer</label>
            <input class="form-control" asp-for="Input.SecurityAnswer" autocomplete="off" />
            <span class="text-danger" asp-validation-for="Input.SecurityAnswer"></span>
        </div>
    }

    <div class="col-12">
        <button type="submit" class="btn btn-primary">Generate Reset Link</button>
        <a class="btn btn-outline-secondary ms-1" asp-page="./Login">Back to Login</a>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.ResetLink))
{
    <hr />
    <div class="alert alert-warning">
        <strong>Development Mode:</strong><br />
        Copy this reset link and open it in a new tab:
        <div class="mt-2">
            <a href="@Model.ResetLink">@Model.ResetLink</a>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}