@page
@model AccountingSystem.Pages.Ledger.IndexModel
@{
    ViewData["Title"] = "Ledger";
}

<h2>Ledger: @Model.Account.AccountNumber - @Model.Account.AccountName</h2>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small">Current Balance</div>
                <div class="display-6 fw-semibold">@Model.Account.Balance.ToString("N2")</div>
            </div>
        </div>
    </div>
</div>

<form method="get" class="row g-2 mb-3">
    <input type="hidden" name="accountId" value="@Model.accountId" />

    <div class="col-md-2">
        <input class="form-control" type="date" name="From" value="@(Model.From?.ToString("yyyy-MM-dd"))" title="Filter from date" />
    </div>
    <div class="col-md-2">
        <input class="form-control" type="date" name="To" value="@(Model.To?.ToString("yyyy-MM-dd"))" title="Filter to date" />
    </div>
    <div class="col-md-3">
        <input class="form-control" name="Search" value="@Model.Search" placeholder="Search amount (optional)" title="Search by debit or credit amount" />
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100" type="submit">Apply</button>
    </div>
    <div class="col-md-3">
        <a class="btn btn-outline-secondary w-100" asp-page="/ChartOfAccounts/Index">Back to Chart</a>
    </div>
</form>

@if (Model.Entries.Count == 0)
{
    <div class="alert alert-secondary">
        No ledger entries found for this account and filter.
    </div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Date</th>
                <th>Description</th>
                <th class="text-end">Debit</th>
                <th class="text-end">Credit</th>
                <th class="text-end">Balance</th>
                <th class="text-end">PR</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Entries)
            {
                <tr>
                    <td>@e.EntryDate.ToShortDateString()</td>
                    <td>@(string.IsNullOrWhiteSpace(e.Description) ? "-" : e.Description)</td>
                    <td class="text-end">@e.Debit.ToString("N2")</td>
                    <td class="text-end">@e.Credit.ToString("N2")</td>
                    <td class="text-end">@e.BalanceAfter.ToString("N2")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary"
                           asp-page="/Journal/Details"
                           asp-route-id="@e.JournalEntryId"
                           title="Open the journal entry for this ledger row">
                            @e.JournalEntryId
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}