@page
@model AccountingSystem.Pages.Admin.ExpiredPasswordsModel
@{
    ViewData["Title"] = "Expired Passwords";
}

<h2>Expired Passwords</h2>

@if (Model.Expired.Count == 0)
{
    <p>No expired passwords found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Expired At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Expired)
            {
                <tr>
                    <td>@r.Username</td>
                    <td>@r.Email</td>
                    <td>@r.ExpiresAtUtc.ToLocalTime()</td>
                </tr>
            }
        </tbody>
    </table>
}
