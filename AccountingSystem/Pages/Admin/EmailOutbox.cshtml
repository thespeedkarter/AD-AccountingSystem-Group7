@page
@model AccountingSystem.Pages.Admin.EmailOutboxModel
@{
    ViewData["Title"] = "Email Outbox";
}

<h2>Email Outbox</h2>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input class="form-control" name="Search" value="@Model.Search" placeholder="Search email/subject" />
    </div>
    <div class="col-md-3">
        <input class="form-control" type="date" name="From" value="@(Model.From?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="col-md-3">
        <input class="form-control" type="date" name="To" value="@(Model.To?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100" type="submit">Apply</button>
    </div>
</form>

@if (Model.Emails.Count == 0)
{
    <p class="text-muted">No emails found.</p>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Sent</th>
                <th>To</th>
                <th>Subject</th>
                <th>Channel</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Emails)
            {
                <tr>
                    <td>@e.SentAtUtc.ToLocalTime()</td>
                    <td>@e.ToEmail</td>
                    <td>@e.Subject</td>
                    <td>@e.Channel</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-page="./EmailOutboxDetails" asp-route-id="@e.SentEmailId">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}