@page
@model AccountingSystem.Pages.Account.ForgotPasswordCustomModel
@{
    ViewData["Title"] = "Forgot Password";
}

<h2>Forgot Password</h2>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<form method="post" class="mt-3">
    <div class="mb-2">
        <label class="form-label">Username</label>
        <input class="form-control" asp-for="Username" />
    </div>

    <div class="mb-2">
        <label class="form-label">Email</label>
        <input class="form-control" asp-for="Email" />
    </div>

    <div class="mb-2">
        <label class="form-label">Security Question</label>
        <input class="form-control" value="@Model.SecurityQuestion" readonly />
        <div class="form-text">If blank, ask an administrator to set your security question.</div>
    </div>

    <div class="mb-2">
        <label class="form-label">Security Answer</label>
        <input class="form-control" asp-for="SecurityAnswer" />
    </div>

    <hr />

    <div class="mb-2">
        <label class="form-label">New Password</label>
        <input class="form-control" asp-for="NewPassword" type="password" />
    </div>

    <div class="mb-2">
        <label class="form-label">Confirm Password</label>
        <input class="form-control" asp-for="ConfirmPassword" type="password" />
    </div>

    <button class="btn btn-primary" type="submit">Reset Password</button>
</form>