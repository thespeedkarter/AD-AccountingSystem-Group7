@page
@model AccountingSystem.Pages.DashboardModel
@using AccountingSystem.Models
@{
    ViewData["Title"] = "Dashboard";
}

<h2>Dashboard / Table of Contents</h2>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Notifications</h5>

                @if (User.IsInRole("Manager") && Model.PendingJournalCount > 0)
                {
                    <div class="alert alert-warning mb-2">
                        You have <strong>@Model.PendingJournalCount</strong> journal entries waiting for approval.
                        <a class="ms-2" asp-page="/Journal/Index" asp-route-Status="@((int)JournalStatus.Pending)">View</a>
                    </div>
                }

                @if (User.IsInRole("Manager") && Model.ApprovedNotPostedCount > 0)
                {
                    <div class="alert alert-info mb-2">
                        There are <strong>@Model.ApprovedNotPostedCount</strong> approved entries not posted yet.
                        <a class="ms-2" asp-page="/Journal/Index" asp-route-Status="@((int)JournalStatus.Approved)">View</a>
                    </div>
                }

                @if (Model.RejectedJournalCount > 0)
                {
                    <div class="alert alert-secondary mb-0">
                        Rejected journal entries: <strong>@Model.RejectedJournalCount</strong>.
                        <a class="ms-2" asp-page="/Journal/Index" asp-route-Status="@((int)JournalStatus.Rejected)">View</a>
                    </div>
                }

                @if (Model.PendingJournalCount == 0 && Model.ApprovedNotPostedCount == 0 && Model.RejectedJournalCount == 0)
                {
                    <div class="text-muted">No alerts right now.</div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Chart of Accounts</h5>
                <p class="card-text small text-muted">Search, filter, add/edit (Admin only), view balances.</p>
                <a class="btn btn-outline-primary w-100" asp-page="/ChartOfAccounts/Index">Open</a>

                @* Event Logs quick link (only if you created a page for it) *@
                <a class="btn btn-outline-secondary w-100 mt-2" asp-page="/Admin/EventLogs">View Event Logs</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Journal</h5>
                <p class="card-text small text-muted">Create/submit entries, approve/reject (Manager), post to ledger.</p>
                <a class="btn btn-outline-primary w-100" asp-page="/Journal/Index">Open</a>

                @if (User.IsInRole("Manager"))
                {
                    <a class="btn btn-outline-success w-100 mt-2" asp-page="/Journal/Index" asp-route-Status="@((int)JournalStatus.Pending)">
                        Pending Approvals
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Ledger</h5>
                <p class="card-text small text-muted">Ledger is opened from a Chart of Accounts account name (click it).</p>
                <a class="btn btn-outline-primary w-100" asp-page="/ChartOfAccounts/Index">Go via Chart</a>
            </div>
        </div>
    </div>
</div>

@if (User.IsInRole("Administrator"))
{
    <hr class="my-4" />
    <h4>Administrator</h4>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Access Requests</h5>
                    <p class="card-text small text-muted">Approve/reject new user requests and assign roles.</p>
                    <a class="btn btn-outline-primary w-100" asp-page="/Admin/AccessRequests">Open</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Expired Passwords</h5>
                    <p class="card-text small text-muted">View users with expired passwords.</p>
                    <a class="btn btn-outline-primary w-100" asp-page="/Admin/ExpiredPasswords">Open</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Suspend User</h5>
                    <p class="card-text small text-muted">Suspend a user between a start and end date.</p>
                    <a class="btn btn-outline-primary w-100" asp-page="/Admin/SuspendUser">Open</a>
                </div>
            </div>
        </div>
    </div>
}

<hr class="my-4" />
<h4>Account</h4>

<div class="row g-3">
    <div class="col-md-4">
        <a class="btn btn-outline-secondary w-100" href="/Identity/Account/Manage">Manage Account</a>
    </div>
    <div class="col-md-4">
        <a class="btn btn-outline-secondary w-100" href="/Identity/Account/ForgotPasswordCustom">Forgot Password</a>
    </div>
    <div class="col-md-4">
        <form method="post" action="/Identity/Account/Logout" class="m-0">
            <button class="btn btn-outline-danger w-100" type="submit">Logout</button>
        </form>
    </div>
</div>