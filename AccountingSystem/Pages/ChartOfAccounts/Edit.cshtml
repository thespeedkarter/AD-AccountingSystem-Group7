@page "{id:int}"
@model AccountingSystem.Pages.ChartOfAccounts.EditModel
@using AccountingSystem.Models
@{
    ViewData["Title"] = "Edit Account";
}

<h2>Edit Account</h2>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div asp-validation-summary="All" class="text-danger"></div>

<form method="post" class="row g-3">
    <input type="hidden" asp-for="Input.ChartAccountId" />
    <input type="hidden" asp-for="Input.AddedAtUtc" />
    <input type="hidden" asp-for="Input.AddedByUserId" />
    <input type="hidden" asp-for="Input.IsActive" />

    <div class="col-md-6">
        <label class="form-label">Account Name</label>
        <input class="form-control" asp-for="Input.AccountName" title="Edit account name" />
    </div>

    <div class="col-md-6">
        <label class="form-label">Account Number</label>
        <input class="form-control" asp-for="Input.AccountNumber" type="number" step="1" title="Edit account number" />
    </div>

    <div class="col-md-12">
        <label class="form-label">Description</label>
        <textarea class="form-control" asp-for="Input.Description" rows="2" title="Edit description"></textarea>
    </div>

    <div class="col-md-4">
        <label class="form-label">Normal Side</label>
        <select class="form-select" asp-for="Input.NormalSide">
            @foreach (var n in Enum.GetValues<NormalSide>())
            {
                <option value="@((int)n)">@n</option>
            }
        </select>
    </div>

    <div class="col-md-4">
        <label class="form-label">Category</label>
        <select class="form-select" asp-for="Input.Category">
            @foreach (var c in Enum.GetValues<AccountCategory>())
            {
                <option value="@((int)c)">@c</option>
            }
        </select>
    </div>

    <div class="col-md-4">
        <label class="form-label">Subcategory</label>
        <input class="form-control" asp-for="Input.Subcategory" />
    </div>

    <div class="col-md-3">
        <label class="form-label">Initial Balance</label>
        <input class="form-control" asp-for="Input.InitialBalance" type="number" step="0.01" />
    </div>

    <div class="col-md-3">
        <label class="form-label">Debit</label>
        <input class="form-control" asp-for="Input.Debit" type="number" step="0.01" />
    </div>

    <div class="col-md-3">
        <label class="form-label">Credit</label>
        <input class="form-control" asp-for="Input.Credit" type="number" step="0.01" />
    </div>

    <div class="col-md-3">
        <label class="form-label">Balance</label>
        <input class="form-control" asp-for="Input.Balance" type="number" step="0.01" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Order</label>
        <input class="form-control" asp-for="Input.OrderCode" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Statement</label>
        <input class="form-control" asp-for="Input.Statement" />
    </div>

    <div class="col-md-4">
        <label class="form-label">Comment</label>
        <input class="form-control" asp-for="Input.Comment" />
    </div>

    <div class="col-12 d-flex gap-2">
        <button class="btn btn-primary" type="submit" title="Save account changes">Save Changes</button>

        @if (Model.Input.IsActive)
        {
            <button class="btn btn-outline-danger"
                    type="submit"
                    asp-page-handler="Deactivate"
                    title="Deactivate this account"
                    onclick="return confirm('Deactivate this account?');">
                Deactivate
            </button>
        }

        <a class="btn btn-outline-secondary" asp-page="./Index">Back</a>
    </div>
</form>