@page
@model AccountingSystem.Pages.ChartOfAccounts.IndexModel
@using AccountingSystem.Models
@{
    ViewData["Title"] = "Chart of Accounts";
}

<h2>Chart of Accounts</h2>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input class="form-control" name="Search" value="@Model.Search" placeholder="Search name or number" title="Search by account name or account number" />
    </div>

    <div class="col-md-2">
        <select class="form-select" name="Category" title="Filter by category">
            <option value="">All Categories</option>
            @foreach (var c in Enum.GetValues<AccountCategory>())
            {
                <option value="@((int)c)" selected="@(Model.Category.HasValue && Model.Category.Value == c ? "selected" : null)">@c</option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <input class="form-control" name="Subcategory" value="@Model.Subcategory" placeholder="Subcategory" title="Filter by subcategory" />
    </div>

    <div class="col-md-2">
        <input class="form-control" name="Amount" value="@(Model.Amount?.ToString("0.00"))" placeholder="Amount" title="Filter by balance amount" />
    </div>

    <div class="col-md-2 d-flex align-items-center">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" name="ShowInactive" value="true" @(Model.ShowInactive ? "checked" : "") />
            <label class="form-check-label">Show inactive</label>
        </div>
    </div>

    <div class="col-md-1">
        <button class="btn btn-primary w-100" type="submit" title="Apply filters">Go</button>
    </div>
</form>

<div class="mb-3 d-flex gap-2 flex-wrap">
    @if (Model.IsAdmin)
    {
        <a class="btn btn-success" asp-page="./Create" title="Add a new account">+ Add Account</a>
    }

    <a class="btn btn-outline-secondary" asp-page="./Index" title="Clear all filters">Reset</a>

    <form method="post" asp-page-handler="ExportCsv" class="d-inline">
        <input type="hidden" name="search" value="@Model.Search" />
        <input type="hidden" name="category" value="@Model.Category" />
        <input type="hidden" name="subcategory" value="@Model.Subcategory" />
        <input type="hidden" name="amount" value="@Model.Amount" />
        <input type="hidden" name="showInactive" value="@Model.ShowInactive" />
        <button class="btn btn-outline-dark" type="submit" title="Download the filtered chart of accounts as CSV">
            Export CSV
        </button>
    </form>
</div>

@if (Model.Accounts.Count == 0)
{
    <div class="alert alert-secondary">No accounts found.</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Order</th>
                <th>Number</th>
                <th>Name</th>
                <th>Category</th>
                <th>Subcategory</th>
                <th>Statement</th>
                <th class="text-end">Initial</th>
                <th class="text-end">Debit</th>
                <th class="text-end">Credit</th>
                <th class="text-end">Balance</th>
                <th>Status</th>
                @if (Model.IsAdmin)
                {
                    <th class="text-end">Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Accounts)
            {
                <tr>
                    <td>@a.OrderCode</td>
                    <td>@a.AccountNumber</td>
                    <td>
                        <a asp-page="/Ledger/Index"
                           asp-route-accountId="@a.ChartAccountId"
                           asp-route-id="@a.ChartAccountId"
                           title="Open this account in the ledger">
                            @a.AccountName
                        </a>
                    </td>
                    <td>@a.Category</td>
                    <td>@a.Subcategory</td>
                    <td>@a.Statement</td>
                    <td class="text-end">@a.InitialBalance.ToString("N2")</td>
                    <td class="text-end">@a.Debit.ToString("N2")</td>
                    <td class="text-end">@a.Credit.ToString("N2")</td>
                    <td class="text-end">@a.Balance.ToString("N2")</td>
                    <td>
                        @if (a.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    @if (Model.IsAdmin)
                    {
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary"
                               asp-page="./Edit"
                               asp-route-id="@a.ChartAccountId"
                               title="Edit this account">
                                Edit
                            </a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
}