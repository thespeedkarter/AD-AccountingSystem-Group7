@page
@model AccountingSystem.Pages.ChartOfAccounts.IndexModel
@using AccountingSystem.Models
@{
    ViewData["Title"] = "Chart of Accounts";
}

<h2>Chart of Accounts</h2>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input class="form-control" name="Search" value="@Model.Search" placeholder="Search by account name or number" />
    </div>

    <div class="col-md-3">
        <select class="form-select" name="Category">
            <option value="">All Categories</option>
            @foreach (var c in Enum.GetValues<AccountCategory>())
            {
                var selected = Model.Category.HasValue && Model.Category.Value == c;
                <option value="@((int)c)" selected="@(selected ? "selected" : null)">@c</option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <input class="form-control" name="Subcategory" value="@Model.Subcategory" placeholder="Subcategory filter" />
    </div>

    <div class="col-md-2 d-flex align-items-center">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" name="ShowInactive" value="true" @(Model.ShowInactive ? "checked" : "") />
            <label class="form-check-label">Show inactive</label>
        </div>
    </div>

    <div class="col-12">
        <button class="btn btn-primary" type="submit">Apply</button>
        <a class="btn btn-outline-secondary" asp-page="./Index">Reset</a>

        <a class="btn btn-outline-dark ms-2" asp-page="./Logs">All Event Logs</a>

        @if (Model.IsAdmin)
        {
            <a class="btn btn-success float-end" asp-page="./Create">+ Add Account</a>
        }
    </div>
</form>

@if (Model.Accounts.Count == 0)
{
    <p>No accounts found.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Number</th>
                <th>Name</th>
                <th>Category</th>
                <th>Subcategory</th>
                <th class="text-end">Balance</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Accounts)
            {
                <tr>
                    <td>@a.AccountNumber</td>
                    <td>
                        <a asp-page="/Ledger/Index" asp-route-accountId="@a.ChartAccountId">
                            @a.AccountName
                        </a>
                    </td>
                    <td>@a.Category</td>
                    <td>@a.Subcategory</td>
                    <td class="text-end">@a.Balance.ToString("N2")</td>
                    <td>@(a.IsActive ? "Active" : "Inactive")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary"
                           asp-page="./Logs"
                           asp-route-RecordId="@a.ChartAccountId">
                            Logs
                        </a>

                        @if (Model.IsAdmin)
                        {
                            <a class="btn btn-sm btn-outline-primary ms-1"
                               asp-page="./Edit"
                               asp-route-id="@a.ChartAccountId">
                                Edit
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
