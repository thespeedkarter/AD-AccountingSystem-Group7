@page
@{
    ViewData["Title"] = "Financial Reports";
}

<h2>Financial Reports</h2>

<p class="text-muted mb-4">
    Generate and review financial reports by date or date range.
</p>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Trial Balance</h5>
                <p class="card-text small text-muted">
                    Review debit and credit balances for all accounts.
                </p>
                <div class="mt-auto">
                    <a class="btn btn-primary w-100" asp-page="./TrialBalance">Open</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Income Statement</h5>
                <p class="card-text small text-muted">
                    Review revenues, expenses, and net income.
                </p>
                <div class="mt-auto">
                    <a class="btn btn-primary w-100" asp-page="./IncomeStatement">Open</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Balance Sheet</h5>
                <p class="card-text small text-muted">
                    Review assets, liabilities, and equity as of a selected date.
                </p>
                <div class="mt-auto">
                    <a class="btn btn-primary w-100" asp-page="./BalanceSheet">Open</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Retained Earnings</h5>
                <p class="card-text small text-muted">
                    Review retained earnings activity and balances.
                </p>
                <div class="mt-auto">
                    <a class="btn btn-primary w-100" asp-page="./RetainedEarnings">Open</a>
                </div>
            </div>
        </div>
    </div>
</div>